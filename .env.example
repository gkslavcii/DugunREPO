# Supabase — Project Settings > API bölümünden alınır
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Yönetim paneli (/admin) şifresi — kendin belirle
ADMIN_PASSWORD=guclu-bir-sifre-yaz

# Cloudflare R2 (fotoğraf depolama) — R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=YOUR-ACCOUNT-ID
R2_ACCESS_KEY_ID=YOUR-ACCESS-KEY-ID
R2_SECRET_ACCESS_KEY=YOUR-SECRET-ACCESS-KEY
R2_BUCKET=dugun-fotograflar
R2_PUBLIC_URL=https://pub-XXXX.r2.dev
